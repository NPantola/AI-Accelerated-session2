{
  "name": "copilot-bootcamp",
  "version": "1.0.0",
  "description": "Monorepo with React frontend and Node backend",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "npm run start --workspace=frontend",
    "start:backend": "npm run start --workspace=backend",
    "test": "npm run test:frontend && npm run test:backend",
    "test:integration": "npm run test:integration --workspace=backend",
    "test:unit": "npm run test:unit --workspace=backend && npm run test --workspace=frontend",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:chrome": "npx playwright test --project=chromium",
    "test:e2e:firefox": "npx playwright test --project=firefox",
    "test:e2e:safari": "npx playwright test --project=webkit",
    "test:e2e:mobile": "npx playwright test --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
    "test:e2e:install": "npx playwright install --with-deps",
    "test:e2e:report": "npx playwright show-report",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:frontend": "npm run test --workspace=frontend",
    "test:backend": "npm run test --workspace=backend",
    "install:all": "npm install && npm run install:frontend && npm run install:backend",
    "install:frontend": "cd packages/frontend && npm install",
    "install:backend": "cd packages/backend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@playwright/test": "^1.40.0",
    "wait-on": "^7.2.0"
  }
}